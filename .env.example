# Copy to .env and fill in values. Never commit .env.

# Razorpay Dashboard → Webhooks → your endpoint → Webhook secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_signing_secret

# Path to Google Cloud service account JSON (Sheets API enabled; share sheet with SA email)
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service-account.json

# Spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=

# Worksheet tab name (must exist; row 1 = headers)
GOOGLE_WORKSHEET_NAME=Payments

SKIP_WEBHOOK_VERIFY=true

# Optional: set to 1 to skip HMAC verification (local testing only; never in production)
# SKIP_WEBHOOK_VERIFY=0
